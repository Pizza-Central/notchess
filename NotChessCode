#piece call and remove funciton
def createPiece(name, color, x, y):
    return piece_classes[name](x, y, color)
def removePiece():
    return board.board[int(pygame.mouse.get_pos()[0] // board.tileSize * board.tileSize // 64)][int(pygame.mouse.get_pos()[1] // board.tileSize * board.tileSize // 64)]

#function to check if placement spot is valid
def checkTile(tile):
    if board.board[int(tile[0])][int(tile[1])] == "_":
        return True
    else:
        return False
    
#pawn promotion funciton
def replaceQueen(coords, color):
    print("hi")
    for sprite in pieces:
        if sprite.rect.collidepoint(coords,0) == piece_classes["pawn"]:
            pieces.remove(sprite)
            pieces.add(createPiece("queen", color, coords[0], 0))
            board.board[coords[0] // 64][0] = piece_classes["queen"]

