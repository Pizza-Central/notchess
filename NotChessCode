def renderText(input):
    text_surface = font.render(str(input), True, (255, 255, 255))
    text_rect = text_surface.get_rect()
    text_rect.center = (512, 512)
    return(text_surface, text_rect)





#board setup class
class Board:

    def __init__ (self, boardSize, screen):
        self.boardSize = boardSize
        self.tile = pygame.Rect(0, 0, boardSize / 16, boardSize / 16)
        self.screen = screen
        self.tileSize = self.boardSize / 16
        self.board = []
        for i in range(16):
            self.board.append([])
            for j in range(16):
                self.board[i].append("_")


    def updateBoard (self):
        a = True
        for i in range(16):
            a = not a
            for j in range(16):
                self.tile = pygame.Rect(i * self.tileSize, j * self.tileSize, self.tileSize, self.tileSize)
                if a:
                    pygame.draw.rect(self.screen, (20, 20, 20), self.tile)
                    a = False
                elif not a:
                    pygame.draw.rect(self.screen, (50, 50, 50), self.tile)
                    a = True


    def updateMouse(self, mousePos):
        self.select = (int(mousePos[0] // self.tileSize * self.tileSize // 64), int(mousePos[1] // self.tileSize * self.tileSize // 64))
        highlight = pygame.Rect(mousePos[0] // self.tileSize * self.tileSize, mousePos[1] // self.tileSize * self.tileSize, boardSize / 16, boardSize / 16)
        pygame.draw.rect(screen, (200, 0, 50), highlight, 3)
        self.board[int(self.select[0])][int(self.select[1])]





