#piece setup class with all piece subclasses
class Piece(pygame.sprite.Sprite):
    def __init__(self, x, y, color, image):
        super().__init__()
        self.coords = pygame.math.Vector2(x, y)
        self.color = color
        self.moves = []
        self.movecoords = []
        self.attacks = []
        self.attackcoords = []
        self.image = pygame.image.load(image).convert_alpha()
        self.rect = self.image.get_rect()
        self.rect.x = x
        self.rect.y = y
        self.pieceSurface = pygame.surface.Surface((64, 64), pygame.SRCALPHA)
        pieces.add(self)

    def getMoves(self):
        pass

    def getAttack(self):
        pass

    def updatePos(self, x, y):
        self.x = x
        self.y = y
        self.rect.x = x
        self.rect.y = y

class Pawn(Piece):
    def __init__(self, x, y, color):
        self.x = x
        self.y = y
        self.color = color
        self.value = 1
        if color == "black":
            image = "~blackpawn.png"
        if color == "white":
            image = "~whitepawn.png"
        super().__init__(x, y, color, image)
        

    def getMoves(self):
        self.moves.clear()
        self.movecoords.clear()
        if self.color == "white":
            if not self.y < 64:
                if board.board[self.x // 64][self.y // 64 - 1] == "_":
                    if len(self.moves) > 0:
                        for i in range(len(self.moves)):
                            if not self.moves[i] == ((self.x // 64, self.y // 64 - 1)):
                                self.moves.append((self.x // 64, self.y // 64 - 1))
                                for i in range(len(self.moves)):
                                    self.movecoords.append(self.x)
                                    self.movecoords.append(self.y - 64)
                        return self.movecoords
                    else:
                        self.moves.append((self.x // 64, self.y // 64 - 1))
                        for i in range(len(self.moves)):
                            self.movecoords.append(self.x)
                            self.movecoords.append(self.y - 64)
                        return self.movecoords
                else:
                    return self.movecoords
            else:
                return (("queen", self.x))


    def getAttack(self):
        self.attackcoords.clear()
        self.attacks.clear()
        if self.color == "white":
            if self.x > 63:
                for sprite in pieces:
                    if sprite.x == self.x - 64:
                        if sprite.y == self.y - 64:
                            if sprite.color == "black":
                                if len(self.attacks) > 0:
                                    for i in range(len(self.attacks)):
                                        if not self.attacks[i] == ((self.x // 64 - 1, self.y // 64 - 1)):
                                            self.attacks.append((self.x // 64 - 1, self.y // 64 - 1))
                                            for i in range(len(self.attacks)):
                                                self.attackcoords.append(self.x - 64)
                                                self.attackcoords.append(self.y - 64)
                                else:
                                    self.attacks.append((self.x // 64 - 1, self.y // 64 - 1))
                                    for i in range(len(self.attacks)):
                                        self.attackcoords.append(self.x - 64)
                                        self.attackcoords.append(self.y - 64)
            if self.x < 1024:
                for sprite in pieces:
                    if sprite.x == self.x + 64:
                        if sprite.y == self.y - 64:
                            if sprite.color == "black":
                                if len(self.attacks) > 0:
                                    for i in range(len(self.attacks)):
                                        if not self.attacks[i] == ((self.x // 64 + 1, self.y // 64 - 1)):
                                            self.attacks.append((self.x // 64 + 1, self.y // 64 - 1))
                                            for i in range(len(self.attacks)):
                                                self.attackcoords.append(self.x + 64)
                                                self.attackcoords.append(self.y - 64)
                                else:
                                    self.attacks.append((self.x // 64 + 1, self.y // 64 - 1))
                                    for i in range(len(self.attacks)):
                                        self.attackcoords.append(self.x + 64)
                                        self.attackcoords.append(self.y - 64)
                return self.attackcoords




